FAL_API_KEY=
REPLICATE_API_TOKEN=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# === Google Drive ===
GDRIVE_OUTPUT_FOLDER_ID=1Vr184ZsX3k38xpmZkd8g2vwB5y9LYMRC
GOOGLE_CREDENTIALS_PATH=

# === Generation Controls ===
VARIANTS_PER_COVER=5
BATCH_CONCURRENCY=1
REQUEST_DELAY=1.0
