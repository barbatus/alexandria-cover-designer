AI_MODEL=flux-2-pro
ALL_MODELS=flux-2-pro,flux-2-schnell,gpt-image-1-high,gpt-image-1-medium,imagen-4-ultra,imagen-4-fast,nano-banana-pro

# === API Keys ===
